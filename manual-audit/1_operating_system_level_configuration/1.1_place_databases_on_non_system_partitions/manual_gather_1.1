---
# ==============================================================================
# TỰ ĐỘNG ĐÁNH GIÁ Mục 1.1: Place Databases on Non-System Partitions
# ==============================================================================

- name: CIS 1.1 - Lấy đường dẫn thư mục chứa dữ liệu (datadir)
  ansible.builtin.command: mysql -N -B -e "SELECT @@datadir;"
  register: mysql_datadir_output
  become: yes
  changed_when: false

- name: CIS 1.1 - Tìm chính xác phân vùng (Mount Point) của datadir
  # Lệnh df -P xuất định dạng chuẩn, awk 'NR==2 {print $6}' sẽ chỉ lấy đúng tên phân vùng ở dòng số 2
  ansible.builtin.shell: df -P {{ mysql_datadir_output.stdout }} | awk 'NR==2 {print $6}'
  register: datadir_mount_point
  become: yes
  changed_when: false

- name: CIS 1.1 - Xử lý logic Đánh giá (Pass/Fail)
  ansible.builtin.set_fact:
    # Nếu phân vùng nằm trong danh sách cấm (/, /var, /usr) thì Fail, ngược lại là Pass
    cis_1_1_status: >-
      {% if datadir_mount_point.stdout in ['/', '/var', '/usr'] %}
      FAIL
      {% else %}
      PASS
      {% endif %}

- name: CIS 1.1 - In Kết Luận
  ansible.builtin.debug:
    msg: 
      - "--- KẾT QUẢ ĐÁNH GIÁ MỤC 1.1 ---"
      - "Đường dẫn datadir     : {{ mysql_datadir_output.stdout }}"
      - "Đang nằm trên phân vùng: {{ datadir_mount_point.stdout }}"
      - ">> TRẠNG THÁI CIS 1.1 : {{ cis_1_1_status }}"